# ============================================
# KBEX.io - Configuração de Produção
# ============================================
# Copie este ficheiro para .env e preencha os valores
# cp .env.example .env
# ============================================

# DOMÍNIO (obrigatório)
# URL do seu site (com https://)
DOMAIN_URL=https://seu-dominio.com

# COINMARKETCAP (obrigatório)
# Obter em: https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=sua_chave_aqui

# JWT SECRET (obrigatório)
# Gerar com: openssl rand -hex 32
JWT_SECRET=gerar_um_secret_de_32_caracteres_aqui

# FIREBLOCKS (opcional)
# Deixar vazio se não usar
FIREBLOCKS_API_KEY=
FIREBLOCKS_BASE_PATH=https://api.fireblocks.io/v1
