# KBEX.io Backend Environment Variables
# Copy this file to .env and fill in the values

# Domain
DOMAIN_URL=https://kbex.io
FRONTEND_URL=https://kbex.io

# Security
JWT_SECRET=your-jwt-secret-here

# API Keys - Market Data
COINMARKETCAP_API_KEY=your-cmc-key
BINANCE_API_KEY=your-binance-key
BINANCE_SECRET_KEY=your-binance-secret

# Sumsub KYC
SUMSUB_APP_TOKEN=your-sumsub-token
SUMSUB_SECRET_KEY=your-sumsub-secret
SUMSUB_LEVEL_NAME=basic-kyc-level

# Brevo Email & CRM
BREVO_API_KEY=your-brevo-key
BREVO_SENDER_EMAIL=no-reply@kbex.io
BREVO_SENDER_NAME=KBEX

# Fireblocks Wallets
FIREBLOCKS_API_KEY=your-fireblocks-key
FIREBLOCKS_SECRET_KEY_PATH=/app/fireblocks_secret.key
FIREBLOCKS_BASE_PATH=https://api.fireblocks.io

# Stripe Payments
STRIPE_API_KEY=your-stripe-key
